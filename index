<script>
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  window.scrollTo(0,0);
}
function doSignIn() {
  document.getElementById('main-nav').style.display = 'none';
  document.getElementById('user-nav').style.display = 'flex';
  showPage('dashboard');
}
function bookClass(btn) {
  if (btn.classList.contains('booked') || btn.classList.contains('full')) return;
  btn.textContent = 'Booked ✓';
  btn.classList.add('booked');
}
function applyFilter(type) {
  document.querySelectorAll('.filter-chip').forEach(c => {
    c.classList.remove('active','active-special');
    if (c.dataset.filter === type) c.classList.add(type === 'special' ? 'active-special' : 'active');
  });
  document.getElementById('clear-btn').classList.toggle('visible', type !== 'all');
  document.querySelectorAll('.class-row').forEach(row => {
    if (type === 'all') { row.classList.remove('dimmed','highlighted'); }
    else if (row.dataset.type === type) { row.classList.remove('dimmed'); row.classList.add('highlighted'); }
    else { row.classList.remove('highlighted'); row.classList.add('dimmed'); }
  });
}
function loadPhoto(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    const img = document.getElementById('hero-photo');
    img.src = e.target.result;
    img.style.display = 'block';
    document.getElementById('photo-placeholder').style.display = 'none';
  };
  reader.readAsDataURL(file);
}
</script>
