  .hero-text p { font-size: 17px; color: var(--gray-700); line-height: 1.7; max-width: 420px; margin-bottom: 2rem; }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary { background: var(--black); color: var(--white); border: none; padding: 14px 30px; border-radius: 8px; font-family: 'DM Sans'; font-size: 15px; font-weight: 500; cursor: pointer; }
  .btn-secondary { background: transparent; color: var(--black); border: 1px solid var(--gray-300); padding: 14px 30px; border-radius: 8px; font-family: 'DM Sans'; font-size: 15px; cursor: pointer; }
  .btn-primary:hover { background: var(--accent); }
  .btn-secondary:hover { border-color: var(--black); }
  .hero-stats { display: flex; gap: 2rem; margin-top: 3rem; padding-top: 2rem; border-top: 0.5px solid var(--gray-100); }
  .stat-val { font-family: 'Bebas Neue', sans-serif; font-size: 36px; letter-spacing: 1px; }
  .stat-label { font-size: 13px; color: var(--gray-500); text-transform: uppercase; letter-spacing: 1px; }
  .hero-visual { display: flex; flex-direction: column; gap: 16px; }
  .home-class-card { background: var(--gray-50); border: 0.5px solid var(--gray-100); border-radius: 12px; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; }
  .home-class-card.featured { background: var(--black); border-color: var(--black); }
  .hci h3 { font-size: 16px; font-weight: 500; color: var(--black); margin-bottom: 4px; }
  .home-class-card.featured .hci h3 { color: var(--white); }
  .hci-meta { font-size: 13px; color: var(--gray-500); display: flex; gap: 12px; }
