  .spots-open { background: #eaf3de; color: #3b6d11; }
  .spots-low { background: #faeeda; color: #854f0b; }
  .spots-full { background: var(--gray-100); color: var(--gray-500); }

  /* SHARED */
  .section { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem; }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 48px; letter-spacing: 1px; margin-bottom: 1.5rem; }
  .section-title span { color: var(--accent); }

  /* ABOUT PAGE */
  .about-page { max-width: 1000px; margin: 0 auto; padding: 3rem 2rem 5rem; }

  /* Hero photo block */
  .photo-block {
    width: 100%;
    height: 420px;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 4rem;
    position: relative;
    background: var(--gray-50);
    border: 0.5px solid var(--gray-100);
  }
  .photo-block img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .photo-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 12px; cursor: pointer;
  }
  .photo-placeholder-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--gray-100);
    display: flex; align-items: center; justify-content: center;
  }
  .photo-placeholder-icon svg { width: 24px; height: 24px; }
  .photo-placeholder p { font-size: 14px; color: var(--gray-500); text-align: center; line-height: 1.6; }
  .photo-placeholder strong { color: var(--black); font-weight: 500; display: block; font-size: 15px; margin-bottom: 4px; }
  .upload-btn {
    padding: 9px 20px; border-radius: 8px; border: 1px solid var(--gray-300);
    background: var(--white); color: var(--black); font-family: 'DM Sans';
    font-size: 13px; cursor: pointer; font-weight: 500; margin-top: 4px;
  }
  .upload-btn:hover { border-color: var(--black); }
  #photo-input { display: none; }

  /* About intro */
  .about-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; margin-bottom: 4rem; }
  .about-intro h2 { font-family: 'Bebas Neue', sans-serif; font-size: 52px; letter-spacing: 1px; line-height: 0.95; margin-bottom: 1.5rem; }
  .about-intro h2 span { color: var(--accent); }
  .about-intro p { font-size: 16px; color: var(--gray-700); line-height: 1.8; margin-bottom: 1rem; }
  .about-intro p:last-child { margin-bottom: 0; }

  /* Values */
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 4rem; }
  .value-card { padding: 1.5rem; background: var(--gray-50); border-radius: 12px; }
  .value-num { font-family: 'Bebas Neue', sans-serif; font-size: 36px; color: var(--accent); letter-spacing: 1px; margin-bottom: 8px; }
  .value-title { font-size: 16px; font-weight: 500; margin-bottom: 8px; }
  .value-desc { font-size: 14px; color: var(--gray-700); line-height: 1.7; }

  /* Divider */
  .about-divider { height: 0.5px; background: var(--gray-100); margin: 0 0 4rem; }

  /* Meet STATION8 — coaches */
  .meet-header { margin-bottom: 2rem; }
  .meet-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 42px; letter-spacing: 1px; }
  .meet-header h2 span { color: var(--accent); }
  .meet-header p { font-size: 15px; color: var(--gray-500); margin-top: 6px; }

  .coaches-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .coach-card { border: 0.5px solid var(--gray-100); border-radius: 12px; overflow: hidden; }
  .coach-avatar { height: 160px; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 52px; letter-spacing: 2px; }
  .coach-info { padding: 16px 18px; }
  .coach-info h3 { font-size: 17px; font-weight: 500; }
  .coach-role { font-size: 12px; color: var(--accent); text-transform: uppercase; letter-spacing: 1px; margin: 4px 0 8px; }
  .coach-bio { font-size: 13px; color: var(--gray-700); line-height: 1.6; }
  .coach-stat { display: inline-block; font-size: 11px; background: var(--gray-50); padding: 3px 10px; border-radius: 20px; margin-top: 10px; margin-right: 6px; color: var(--gray-700); }

  /* DASHBOARD */
  .dashboard { max-width: 1200px; margin: 0 auto; padding: 2rem; }
  .dashboard-header { margin-bottom: 2rem; }
  .dashboard-header h1 { font-family: 'Bebas Neue', sans-serif; font-size: 40px; letter-spacing: 1px; }
  .dashboard-header p { font-size: 15px; color: var(--gray-500); margin-top: 4px; }
  .metrics-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; margin-bottom: 2rem; }
  .metric-card { background: var(--gray-50); border-radius: 10px; padding: 1rem; }
  .metric-label { font-size: 13px; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
  .metric-val { font-family: 'Bebas Neue', sans-serif; font-size: 30px; letter-spacing: 1px; }
  .metric-sub { font-size: 12px; color: var(--gray-500); margin-top: 2px; }
  .dash-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }
  .dash-card { background: var(--white); border: 0.5px solid var(--gray-100); border-radius: 12px; padding: 1.25rem; }
  .dash-card h3 { font-size: 15px; font-weight: 500; margin-bottom: 1rem; padding-bottom: 12px; border-bottom: 0.5px solid var(--gray-100); }
  .schedule-item { display: flex; align-items: center; gap: 12px; padding: 11px 0; border-bottom: 0.5px solid var(--gray-100); }
  .schedule-item:last-child { border-bottom: none; }
  .schedule-time { font-size: 13px; color: var(--gray-500); min-width: 55px; }
  .schedule-name { font-size: 15px; font-weight: 500; }
  .schedule-coach { font-size: 13px; color: var(--gray-500); }
  .cancel-btn { margin-left: auto; font-size: 12px; color: var(--accent); cursor: pointer; background: none; border: none; font-family: 'DM Sans'; }

  /* RESULTS */
  .results-table { width: 100%; border-collapse: collapse; font-size: 15px; }
  .results-table th { text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 0.8px; color: var(--gray-500); padding: 0 12px 12px 12px; border-bottom: 0.5px solid var(--gray-100); }
  .results-table td { padding: 14px 12px; border-bottom: 0.5px solid var(--gray-100); }
  .results-table tr:last-child td { border-bottom: none; }
  .results-table tr:hover td { background: var(--gray-50); }
  .rank-badge { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 500; }
  .rank-1 { background: #faeeda; color: #854f0b; }
  .rank-2 { background: var(--gray-100); color: var(--gray-700); }
  .rank-3 { background: #faece7; color: #993c1d; }
  .rank-other { background: var(--gray-50); color: var(--gray-500); }
  .time-val { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 1px; }
  .pr-badge { font-size: 11px; background: #eaf3de; color: #3b6d11; padding: 2px 8px; border-radius: 20px; margin-left: 8px; font-weight: 500; }

  /* SIGN IN */
  .signin-wrap { min-height: calc(100vh - 68px); display: flex; align-items: center; justify-content: center; padding: 2rem; background: var(--gray-50); }
  .signin-card { background: var(--white); border: 0.5px solid var(--gray-100); border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 420px; }
  .signin-logo { font-family: 'Bebas Neue', sans-serif; font-size: 32px; letter-spacing: 2px; text-align: center; margin-bottom: 0.5rem; }
  .signin-logo span { color: var(--accent); }
  .signin-sub { font-size: 14px; color: var(--gray-500); text-align: center; margin-bottom: 2rem; }
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 13px; color: var(--gray-700); margin-bottom: 6px; font-weight: 500; }
  .field input { width: 100%; padding: 11px 14px; border: 0.5px solid var(--gray-300); border-radius: 8px; font-family: 'DM Sans'; font-size: 15px; color: var(--black); outline: none; }
  .field input:focus { border-color: var(--black); }
  .btn-full { width: 100%; padding: 13px; border-radius: 8px; font-family: 'DM Sans'; font-size: 15px; font-weight: 500; cursor: pointer; margin-top: 6px; }
  .btn-signin { background: var(--black); color: var(--white); border: none; }
  .btn-signin:hover { background: var(--accent); }
  .signin-footer { text-align: center; margin-top: 1.5rem; font-size: 14px; color: var(--gray-500); }
  .signin-footer a { color: var(--black); cursor: pointer; text-decoration: none; font-weight: 500; }

  /* SCHEDULE */
  .schedule-page { max-width: 860px; margin: 0 auto; padding: 2.5rem 2rem 5rem; }
  .schedule-page > h1 { font-family: 'Bebas Neue', sans-serif; font-size: 42px; letter-spacing: 1px; margin-bottom: 1.5rem; }
  .schedule-page > h1 span { color: var(--accent); }
  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 2.5rem; }
  .filter-chip { padding: 7px 16px; border-radius: 100px; font-size: 13px; font-weight: 500; border: 1px solid var(--gray-100); cursor: pointer; font-family: 'DM Sans'; background: var(--white); color: var(--gray-700); white-space: nowrap; }
  .filter-chip:hover { border-color: var(--gray-500); color: var(--black); }
  .filter-chip.active { background: var(--black); color: var(--white); border-color: var(--black); }
  .filter-chip.active-special { background: #854f0b; color: var(--white); border-color: #854f0b; }
  .filter-clear { padding: 7px 14px; border-radius: 100px; font-size: 13px; border: 1px dashed var(--gray-300); cursor: pointer; font-family: 'DM Sans'; background: transparent; color: var(--accent); display: none; }
  .filter-clear.visible { display: block; }
  .day-group { margin-bottom: 2.5rem; }
  .day-label { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px; color: var(--black); text-transform: uppercase; margin-bottom: 6px; padding-bottom: 10px; border-bottom: 1px solid var(--gray-100); }
  .session-label { font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: var(--gray-500); font-weight: 500; margin: 14px 0 8px 4px; }
  .class-row { display: grid; grid-template-columns: 76px 1fr auto; align-items: center; gap: 14px; padding: 13px 16px; border-radius: 10px; border: 0.5px solid var(--gray-100); margin-bottom: 7px; background: var(--white); transition: opacity 0.18s, border-color 0.18s; }
  .class-row:hover:not(.dimmed) { border-color: var(--gray-300); }
  .class-row.dimmed { opacity: 0.22; }
  .class-row.dimmed .book-btn { pointer-events: none; }
  .class-row.highlighted { border-color: var(--black); }
  .class-row.highlighted.special-row { border-color: #ef9f27; }
  .row-time { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 1px; color: var(--black); line-height: 1.1; }
  .row-time-ampm { font-size: 11px; font-family: 'DM Sans'; color: var(--gray-500); font-weight: 400; letter-spacing: 0; display: block; }
  .row-time-dur { font-size: 10px; font-family: 'DM Sans'; color: var(--gray-300); letter-spacing: 0; display: block; }
  .row-info { min-width: 0; }
  .row-tag { font-size: 10px; text-transform: uppercase; letter-spacing: 1.2px; color: var(--accent); font-weight: 500; margin-bottom: 2px; }
  .row-tag.tag-special { color: #854f0b; }
  .row-name { font-size: 15px; font-weight: 500; margin-bottom: 3px; }
  .row-meta { font-size: 12px; color: var(--gray-500); display: flex; gap: 10px; flex-wrap: wrap; }
  .row-action { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; min-width: 96px; }
  .book-btn { padding: 8px 16px; background: var(--black); color: var(--white); border: none; border-radius: 8px; font-family: 'DM Sans'; font-size: 13px; cursor: pointer; font-weight: 500; white-space: nowrap; width: 100%; text-align: center; }
  .book-btn:hover:not(:disabled) { background: var(--accent); }
  .book-btn.booked { background: #3b6d11; color: var(--white); cursor: default; }
  .book-btn.full { background: var(--gray-100); color: var(--gray-500); cursor: default; }
  .spots-pill { font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 500; white-space: nowrap; text-align: center; width: 100%; }
  .class-row.mock-race-row { background: var(--black); border-color: var(--black); }
  .class-row.mock-race-row .row-time { color: var(--white); }
  .class-row.mock-race-row .row-time-ampm { color: var(--gray-500); }
  .class-row.mock-race-row .row-time-dur { color: var(--gray-700); }
  .class-row.mock-race-row .row-tag { color: var(--accent); }
  .class-row.mock-race-row .row-name { color: var(--white); }
  .class-row.mock-race-row .row-meta { color: var(--gray-500); }
  .class-row.mock-race-row .book-btn { background: var(--white); color: var(--black); }
  .class-row.mock-race-row .book-btn:hover:not(:disabled) { background: var(--accent); color: var(--white); }
  .class-row.mock-race-row.dimmed { opacity: 0.18; }
</style>

